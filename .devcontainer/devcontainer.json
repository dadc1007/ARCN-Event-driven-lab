{
  "name": "Java Spring Event Lab",
  "image": "mcr.microsoft.com/devcontainers/java:0-17",
  "features": {
    // Habilita Docker-in-Docker para construir y correr contenedores dentro del dev container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    },
    // Configuración de Java y Maven
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": "true",
      "mavenVersion": "3.8.6"
    }
  },
  "forwardPorts": [
    8080, // Productor
    8081, // Consumidor
    5672, // RabbitMQ Broker
    15672 // RabbitMQ Dashboard
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "ms-azuretools.vscode-docker",
        "redhat.java",
        "vscjava.vscode-maven"
      ],
      "settings": {
        // Configuración para que Docker VS Code use el socket interno
        "docker.host": "unix:///var/run/docker.sock"
      }
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "docker --version && mvn -version"
}
